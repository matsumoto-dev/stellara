# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-your-key

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx

# Demo account (optional — if unset, demo button is hidden on login page)
NEXT_PUBLIC_DEMO_ENABLED=true
DEMO_EMAIL=demo@stellara.chat
DEMO_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# QA testing (required for qa-screenshots.ts)
QA_TEST_EMAIL=qa-test@stellara.chat
QA_TEST_PASSWORD=your-qa-password
